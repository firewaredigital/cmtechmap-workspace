# ==============================================================================
# CM TECHMAP — Environment Variables
# Copy this file to .env and adjust values for your environment
# ==============================================================================

# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=cm-techmap
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0
APP_SECRET_KEY=CHANGE-ME-to-a-random-64-character-string-in-production
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── FastAPI / Uvicorn ────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_LOG_LEVEL=info

# ─── PostgreSQL + PostGIS ─────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cm_techmap
POSTGRES_USER=cm_techmap
POSTGRES_PASSWORD=cm_techmap_dev_2026
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
DATABASE_URL_SYNC=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ─── Keycloak PostgreSQL (internal) ───────────────────────────────────────────
KC_POSTGRES_DB=keycloak
KC_POSTGRES_USER=keycloak
KC_POSTGRES_PASSWORD=keycloak_dev_2026

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0
CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0
CELERY_RESULT_BACKEND=redis://${REDIS_HOST}:${REDIS_PORT}/1

# ─── MinIO (S3-Compatible Object Storage) ─────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=cm_techmap_admin
MINIO_ROOT_PASSWORD=cm_techmap_minio_2026
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false
MINIO_BUCKET_RAW_UPLOADS=raw-uploads
MINIO_BUCKET_ORTHOMOSAICS=orthomosaics
MINIO_BUCKET_POINT_CLOUDS=point-clouds
MINIO_BUCKET_ELEVATION_MODELS=elevation-models
MINIO_BUCKET_3D_MODELS=3d-models
MINIO_BUCKET_REPORTS=reports
MINIO_BUCKET_BACKUPS=backups

# ─── Keycloak (Identity & Access Management) ──────────────────────────────────
KEYCLOAK_SERVER_URL=http://keycloak:8080
KEYCLOAK_EXTERNAL_URL=http://localhost:8080
KEYCLOAK_REALM=cm-techmap
KEYCLOAK_CLIENT_ID=cm-techmap-api
KEYCLOAK_CLIENT_SECRET=CHANGE-ME-after-keycloak-setup
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE-ME-strong-admin-password

# ─── Flower (Celery Monitoring) ───────────────────────────────────────────────
FLOWER_PORT=5555
FLOWER_BASIC_AUTH=admin:flower_dev_2026

# ─── NodeODM (Photogrammetry Engine) ─────────────────────────────────────────
NODEODM_HOST=nodeodm
NODEODM_PORT=3000
NODEODM_TIMEOUT=30
NODEODM_POLL_INTERVAL=10

# ─── TiTiler (Raster Tile Server) ────────────────────────────────────────────
TITILER_URL=http://titiler:8888
TITILER_EXTERNAL_URL=http://localhost:18888

# ─── Martin (Vector Tile Server) ─────────────────────────────────────────────
MARTIN_URL=http://martin:3000
MARTIN_EXTERNAL_URL=http://localhost:13001
