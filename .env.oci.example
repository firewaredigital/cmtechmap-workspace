# ==============================================================================
# CM TECHMAP — OCI Always Free — Environment Variables Example
# Copie para .env.oci e ajuste os valores (ou use setup-oci-vm.sh para gerar)
# ==============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
APP_CORS_ORIGINS=http://SEU_IP,https://SEU_IP
API_LOG_LEVEL=warning

# ── Domain (descomente quando tiver DNS) ─────────────────────────────────────
# DOMAIN_NAME=mapa.suaprefeitura.gov.br

# ── Workers ──────────────────────────────────────────────────────────────────
GUNICORN_WORKERS=2
CELERY_CONCURRENCY=2
CELERY_AUTOSCALE=4,1

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=cm_techmap
POSTGRES_USER=cm_techmap_oci
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
KC_POSTGRES_DB=keycloak

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_MAX_MEMORY=256mb

# ── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=cm_techmap_oci
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Keycloak ─────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
KEYCLOAK_REALM=cm-techmap
KEYCLOAK_CLIENT_ID=cm-techmap-api
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Flower ───────────────────────────────────────────────────────────────────
FLOWER_BASIC_AUTH=admin:CHANGE_ME_PASSWORD

# ── Backup ───────────────────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=14
BACKUP_CRON_SCHEDULE=0 3 * * *
BACKUP_S3_BUCKET=cm-techmap-backups
