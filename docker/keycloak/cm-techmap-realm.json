{
  "id": "cm-techmap",
  "realm": "cm-techmap",
  "displayName": "CM TECHMAP — Inteligência Urbana",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "passwordPolicy": "length(8) and upperCase(1) and lowerCase(1) and digits(1)",
  "defaultSignatureAlgorithm": "RS256",
  "accessTokenLifespan": 86400,
  "ssoSessionIdleTimeout": 86400,
  "ssoSessionMaxLifespan": 86400,
  "roles": {
    "realm": [
      {
        "name": "super_admin",
        "description": "Super Administrator — full platform access, tenant management, user deletion",
        "composite": false
      },
      {
        "name": "tenant_admin",
        "description": "Tenant Administrator — manages users, projects, billing within a municipality",
        "composite": false
      },
      {
        "name": "gestor",
        "description": "Manager — creates and manages projects, generates reports, views analytics",
        "composite": false
      },
      {
        "name": "operador",
        "description": "Operator — uploads drone photos, creates flights, runs processing",
        "composite": false
      },
      {
        "name": "viewer",
        "description": "Viewer — read-only access to maps, reports, and dashboard",
        "composite": false
      }
    ]
  },
  "clients": [
    {
      "clientId": "cm-techmap-api",
      "name": "CM TECHMAP Backend API",
      "description": "Confidential client for the FastAPI backend server",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "cm-techmap-api-dev-secret-2026",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "redirectUris": [
        "http://localhost:8000/*",
        "http://localhost/*",
        "http://143.47.116.9/*",
        "https://cm-techmap-frontend.vercel.app/*"
      ],
      "webOrigins": [
        "http://localhost:8000",
        "http://localhost",
        "http://143.47.116.9",
        "https://cm-techmap-frontend.vercel.app"
      ],
      "attributes": {
        "access.token.lifespan": "86400",
        "client.session.idle.timeout": "86400"
      },
      "protocolMappers": [
        {
          "name": "tenant_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "claim.name": "tenant_id",
            "user.attribute": "tenant_id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "jsonType.label": "String"
          }
        },
        {
          "name": "department",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "claim.name": "department",
            "user.attribute": "department",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "jsonType.label": "String"
          }
        },
        {
          "name": "realm_roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "roles",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "cm-techmap-frontend",
      "name": "CM TECHMAP Frontend SPA",
      "description": "Public client for the React/PatternFly frontend application",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "implicitFlowEnabled": false,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:5174/*",
        "http://localhost:3000/*",
        "http://localhost/*",
        "http://143.47.116.9/*",
        "https://cm-techmap-frontend.vercel.app/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:5174",
        "http://localhost:3000",
        "http://localhost",
        "http://143.47.116.9",
        "https://cm-techmap-frontend.vercel.app"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:5173/*"
      }
    }
  ],
